# ── Veritabanı ───────────────────────────────────────────────
# Lokal Docker (docker-compose.yml) için:
#   postgresql://fener:fener@localhost:5432/fener
# Neon için Neon connection string'ini yapıştır.
DATABASE_URL=

# ── MQTT (HiveMQ Cloud) ──────────────────────────────────────
# TLS/SSL zorunlu — düz 1883 desteklenmez.
MQTT_HOST=            # xxxx.s1.eu.hivemq.cloud
MQTT_PORT=8883        # TLS
MQTT_USER=
MQTT_PASS=

# ── Uygulama ─────────────────────────────────────────────────
# Dashboard'ın dinleyeceği SSE endpoint'i (aynı origin).
NEXT_PUBLIC_SSE_URL=/api/events
